# app
APP_ENV=$APP_ENV

# redis
REDIS_URL=$REDIS_URL
REDIS_DB=$REDIS_DB

# misc
SERVER_SECRET=$SERVER_SECRET

# contentful
CONTENTFUL_SPACE_ID=$CONTENTFUL_SPACE_ID
CONTENTFUL_ENVIROMENT=$CONTENTFUL_ENVIROMENT
CONTENTFUL_CDA_TOKEN=$CONTENTFUL_CDA_TOKEN
