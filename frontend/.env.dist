# external api
EA_FIGHT_DATA_API_TOKEN=$EA_FIGHT_DATA_API_TOKEN

# Logging
LOG_TO_FILE=0
LOG_TO_GCP=1
GCP_LOG_PROJECT=
GCP_LOG_KEYFILE=
GCP_REPORTING_NAME=$GCP_REPORTING_NAME
LOG_LEVEL=warning