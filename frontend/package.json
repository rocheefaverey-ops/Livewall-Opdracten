{
  "name": "nextapp",
  "version": "0.1.0",
  "private": true,
  "repository": ".",
  "scripts": {
    "dev": "next dev",
    "dev:ts": "npm run dev",
    "ts-compile": "tsc --noEmit",
    "ts:watch": "eslint ./**/*.{ts,tsx} --watch",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "cd .. && node -e \"if (process.env.NODE_ENV === 'development'){process.exit(1)} \" || husky install frontend/.husky",
    "lint-staged": "lint-staged",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --color --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@google-cloud/error-reporting": "3.0.5",
    "@google-cloud/logging-winston": "6.0.0",
    "@svgr/webpack": "8.1.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "classnames": "2.5.1",
    "date-fns": "^4.1.0",
    "luxon": "3.5.0",
    "next": "^15.1.5",
    "next-i18n-router": "^5.5.1",
    "next-nprogress-bar": "^2.4.3",
    "react": "19.0.0",
    "react-datepicker": "7.6.0",
    "react-dom": "19.0.0",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.1.5",
    "@types/luxon": "3.4.2",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-datepicker": "7.0.0",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "6.4.0",
    "@typescript-eslint/parser": "6.4.0",
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "eslint": "8.47.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "17.1.0",
    "eslint-config-next": "13.4.19",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "husky": "9.1.7",
    "lint-staged": "^15.4.1",
    "postcss": "^8.5.1",
    "postcss-import": "16.1.0",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3"
  }
}
