{
  "name": "nextapp",
  "version": "0.1.0",
  "private": true,
  "repository": ".",
  "scripts": {
    "dev": "next dev",
    "dev:ts": "npm run dev",
    "ts-compile": "tsc --noEmit",
    "ts:watch": "eslint ./**/*.{ts,tsx} --watch",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "cd .. && node -e \"if (process.env.NODE_ENV === 'development'){process.exit(1)} \" || husky install frontend/.husky",
    "lint-staged": "lint-staged",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --color --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@google-cloud/error-reporting": "3.0.5",
    "@google-cloud/logging-winston": "6.0.0",
    "@pinecone-database/pinecone": "^1.1.2",
    "@svgr/webpack": "8.1.0",
    "axios": "^1.6.2",
    "classnames": "2.3.2",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.16",
    "langchain": "^0.0.203",
    "luxon": "3.4.0",
    "next": "^13.5.6",
    "next-i18next": "14.0.0",
    "next-progress": "2.3.1",
    "openai": "^4.20.1",
    "pdf-parse": "^1.1.1",
    "pinecone-client": "^2.0.0",
    "react": "18.2.0",
    "react-datepicker": "4.16.0",
    "react-dom": "18.2.0",
    "winston": "3.10.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "13.4.19",
    "@types/luxon": "3.3.1",
    "@types/node": "20.5.1",
    "@types/react": "18.2.20",
    "@types/react-datepicker": "4.15.0",
    "@types/react-dom": "18.2.7",
    "@typescript-eslint/eslint-plugin": "6.4.0",
    "@typescript-eslint/parser": "6.4.0",
    "autoprefixer": "10.4.15",
    "cross-env": "7.0.3",
    "eslint": "8.47.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "17.1.0",
    "eslint-config-next": "13.4.19",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "husky": "8.0.3",
    "lint-staged": "14.0.1",
    "postcss": "^8.4.32",
    "postcss-import": "15.1.0",
    "prettier": "3.0.2",
    "tailwindcss": "3.3.3",
    "typescript": "5.1.6"
  }
}
