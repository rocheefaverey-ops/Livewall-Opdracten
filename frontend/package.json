{
  "name": "nextapp",
  "version": "0.1.0",
  "private": true,
  "repository": ".",
  "scripts": {
    "dev": "next dev",
    "dev:ts": "npm run dev",
    "ts-compile": "tsc --noEmit",
    "ts:watch": "eslint ./**/*.{ts,tsx} --watch",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "cd .. && node -e \"if (process.env.NODE_ENV === 'development'){process.exit(1)} \" || husky install frontend/.husky",
    "lint-staged": "lint-staged",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --color --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@google-cloud/error-reporting": "3.0.5",
    "@google-cloud/logging-winston": "6.0.0",
    "@svgr/webpack": "8.1.0",
    "axios": "^1.7.5",
    "class-variance-authority": "^0.7.0",
    "classnames": "2.5.1",
    "date-fns": "^3.6.0",
    "luxon": "3.5.0",
    "next": "^14.2.6",
    "next-i18n-router": "^5.5.1",
    "next-nprogress-bar": "^2.3.13",
    "react": "18.3.1",
    "react-datepicker": "7.3.0",
    "react-dom": "18.3.1",
    "winston": "3.14.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "14.2.6",
    "@types/luxon": "3.4.2",
    "@types/node": "22.5.0",
    "@types/react": "18.3.4",
    "@types/react-datepicker": "6.2.0",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.3.0",
    "@typescript-eslint/parser": "8.3.0",
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "eslint": "9.9.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "18.0.0",
    "eslint-config-next": "14.2.6",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "husky": "9.1.5",
    "lint-staged": "15.2.9",
    "postcss": "^8.4.41",
    "postcss-import": "16.1.0",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4"
  }
}
